{
  "expo": {
    "name": " ",
    "slug": " ",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash.svg",
    "scheme": "saraya",

    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.svg"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.svg",
        "backgroundColor": "#dc2626"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.svg"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
